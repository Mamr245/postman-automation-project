    {
      "name": "Get Item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonResponseData = pm.response.json();    \r",
              "const schema = \r",
              "{\r",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "  \"title\": \"DeviceSchema\",\r",
              "  \"type\": \"object\",\r",
              "  \"required\": [\"id\", \"name\", \"data\"],\r",
              "  \"properties\": {\r",
              "    \"id\": {\r",
              "      \"type\": \"string\",\r",
              "      \"description\": \"Unique identifier of the device\"\r",
              "    },\r",
              "    \"name\": {\r",
              "      \"type\": \"string\",\r",
              "      \"description\": \"Device name\"\r",
              "    },\r",
              "    \"data\": {\r",
              "      \"type\": \"object\",\r",
              "      \"description\": \"Additional attributes of the device\",\r",
              "      \"additionalProperties\": {\r",
              "        \"oneOf\": [\r",
              "          { \"type\": \"string\" },\r",
              "          { \"type\": \"number\" },\r",
              "          { \"type\": \"boolean\" }\r",
              "        ]\r",
              "      }\r",
              "    }\r",
              "  },\r",
              "  \"additionalProperties\": false\r",
              "};\r",
              "\r",
              "pm.test(`${pm.info.requestName}: Status code is 200`, function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(`${pm.info.requestName}: Schema is valid`, function () {\r",
              "    pm.expect(pm.response.json()).to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "if (pm.collectionVariables.get(\"id\") === \"9\") {\r",
              "    pm.test(`${pm.info.requestName}: Returned data is correct`, function () {\r",
              "        pm.expect(jsonResponseData.id).to.eql(\"9\");\r",
              "        pm.expect(jsonResponseData.name).to.eql(\"Beats Studio3 Wireless\");\r",
              "        pm.expect(jsonResponseData.data[\"Color\"]).to.eql(\"Red\");\r",
              "        pm.expect(jsonResponseData.data[\"Description\"]).to.eql(\"High-performance wireless noise cancelling headphones\");\r",
              "    });\r",
              "} else {\r",
              "    pm.test(`${pm.info.requestName}: Returned data is correct`, function () {\r",
              "        pm.expect(jsonResponseData.id).to.eql(pm.collectionVariables.get(\"id\"));\r",
              "        pm.expect(jsonResponseData.name).to.eql(\"ASUS ROG STRIX G614JI-93A47CB1\");  \r",
              "        pm.expect(jsonResponseData.data.year).to.eql(2023);\r",
              "        pm.expect(jsonResponseData.data.price).to.eql(parseFloat(pm.collectionVariables.get(\"expectedPrice\")));\r",
              "        pm.expect(jsonResponseData.data[\"CPU model\"]).to.eql(\"Intel Core i9\");\r",
              "        pm.expect(jsonResponseData.data[\"Hard disk size\"]).to.eql(\"1 TB\");\r",
              "        pm.expect(jsonResponseData.data[\"Graphics card\"]).to.eql(\"NVIDIA GeForce RTX 4070\");\r",
              "        pm.expect(jsonResponseData.data[\"RAM memory\"]).to.eql(pm.collectionVariables.get(\"expectedRamMemory\"));\r",
              "    });\r",
              "}\r",
              "\r",
              "if (pm.collectionVariables.get(\"isCollectionRun\").toLowerCase() === \"true\" && pm.collectionVariables.get(\"id\")  === \"9\" ) {\r",
              "    pm.execution.setNextRequest(\"Put Item - Put unallowed\");\r",
              "} else if (pm.collectionVariables.get(\"isCollectionRun\").toLowerCase() === \"true\" \r",
              "&& pm.collectionVariables.get(\"isPutNext\").toLowerCase() === \"true\") {\r",
