    {
      "name": "Post Item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonResponseData = pm.response.json();    ",
              "const schema = ",
              "{",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",",
              "  \"type\": \"object\",",
              "  \"properties\": {",
              "    \"id\": {",
              "      \"type\": \"string\"",
              "    },",
              "    \"name\": {",
              "      \"type\": \"string\"",
              "    },",
              "    \"createdAt\": {",
              "      \"type\": \"integer\"",
              "    },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"properties\": {",
              "        \"year\": {",
              "          \"type\": \"integer\"",
              "        },",
              "        \"price\": {",
              "          \"type\": \"number\"",
              "        },",
              "        \"CPU model\": {",
              "          \"type\": \"string\"",
              "        },",
              "        \"Hard disk size\": {",
              "          \"type\": \"string\"",
              "        }",
              "      },",
              "      \"additionalProperties\": true",
              "    }",
              "  },",
              "  \"required\": [\"id\", \"name\", \"createdAt\", \"data\"]",
              "};",
              "",
              "pm.test(`${pm.info.requestName}: Status code is 200`, function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(`${pm.info.requestName}: Schema is valid`, function () {",
              "    pm.expect(pm.response.json()).to.have.jsonSchema(schema);",
              "});",
              "",
              "pm.test(`${pm.info.requestName}: Returned data is correct`, function () {",
              "    pm.expect(jsonResponseData.id).to.be.a('string');",
              "    pm.expect(jsonResponseData.name).to.eql(\"ASUS ROG STRIX G614JI-93A47CB1\");",
              "    pm.expect(Math.abs(jsonResponseData.createdAt - Date.now())).to.be.at.most(10000);",
              "    pm.expect(jsonResponseData.data.year).to.eql(2023);",
              "    pm.expect(jsonResponseData.data.price).to.eql(2499.99);",
              "    pm.expect(jsonResponseData.data[\"CPU model\"]).to.eql(\"Intel Core i9\");",
              "    pm.expect(jsonResponseData.data[\"Hard disk size\"]).to.eql(\"1 TB\");",
              "    pm.expect(jsonResponseData.data[\"Graphics card\"]).to.eql(\"NVIDIA GeForce RTX 4070\");",
              "    pm.expect(jsonResponseData.data[\"RAM memory\"]).to.eql(\"16 GB\");",
              "});",
              "",
              "if (pm.collectionVariables.get(\"isCollectionRun\").toLowerCase() === \"true\") {",
              "    pm.collectionVariables.set(\"id\", jsonResponseData.id);",
              "    pm.collectionVariables.set(\"isPutNext\", \"true\");  ",
              "    pm.execution.setNextRequest(\"Get Item\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
