            "exec": [
              "var jsonResponseData = pm.response.json();    \r",
              "const schema = \r",
              "{\r",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "  \"title\": \"DeviceListSchema\",\r",
              "  \"type\": \"array\",\r",
              "  \"items\": {\r",
              "    \"type\": \"object\",\r",
              "    \"required\": [\"id\", \"name\", \"data\"],\r",
              "    \"properties\": {\r",
              "      \"id\": {\r",
              "        \"type\": \"string\",\r",
              "        \"description\": \"Unique identifier\"\r",
              "      },\r",
              "      \"name\": {\r",
              "        \"type\": \"string\",\r",
              "        \"description\": \"Device name\"\r",
              "      },\r",
              "      \"data\": {\r",
              "        \"description\": \"Additional device attributes\",\r",
              "        \"type\": [\"object\", \"null\"],\r",
              "        \"additionalProperties\": {\r",
              "          \"oneOf\": [\r",
              "            { \"type\": \"string\" },\r",
              "            { \"type\": \"number\" },\r",
              "            { \"type\": \"boolean\" }\r",
              "          ]\r",
              "        }\r",
              "      }\r",
